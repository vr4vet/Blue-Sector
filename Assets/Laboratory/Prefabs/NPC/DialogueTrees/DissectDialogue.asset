MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1e00f7924afa24219a5197b2a8fa8d48, type: 3}
  m_Name: DissectDialogue
  m_EditorClassIdentifier: 
  shouldTriggerOnProximity: 1
  speakButtonOnExit: 1
  sections:
  - dialogue:
    - 'Next you will dissect the fish. Place the fish on the cutting board to the
      right of the length measurer.

'
    - The first step is checking for any external damages or errors on the fish.
      Check the skin, fins and gills to make sure there are no health issues.
    endAfterDialogue: 0
    disabkeSkipLineButton: 0
    branchPoint:
      question: Did you understand everything?
      answers:
      - answerLabel: Yes
        nextElement: 1
        endAfterAnswer: 0
      - answerLabel: No
        nextElement: 0
        endAfterAnswer: 0
  - dialogue:
    - 'The next step is inspecting the internal areas of the fish. Cut open the fish
      according to the instructions.

'
    - Look after any internal bleeding or discoloration on the fish organs or any
      other damages.
    - Remember to be careful when handling the fish to avoid causing any damage.
    endAfterDialogue: 0
    disabkeSkipLineButton: 0
    branchPoint:
      question: Did you understand everything?
      answers:
      - answerLabel: Yes
        nextElement: 0
        endAfterAnswer: 0
      - answerLabel: No
        nextElement: 1
        endAfterAnswer: 0
